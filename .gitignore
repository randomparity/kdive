# Editor
*.swp

# Python bytecode
__pycache__/
*.pyc

# Virtual environment
.venv/

# Tool caches
.ruff_cache/
.pytest_cache/
.ty_cache/
.hypothesis/
.desloppify/

# Node (mermaid doc checker tooling)
node_modules/

# Generated build info (baked into artifacts only; never committed)
/src/kdive/_buildinfo.py

# Build artifacts
/dist/
build/
*.egg-info/

# Live-stack report artifacts (default is out-of-tree; this guards a repo-local override)
kdive-live-stack-artifacts/

# Agents and orchestration
.claude-flow/
.swarm/

# Helm subchart tarballs — regenerated from Chart.lock by `helm dependency build`
# (the demo-only bundledBackends path); Chart.lock pins the exact versions/digests.
/deploy/helm/kdive/charts/

# Local operator deploy artifacts (may embed backend credentials)
.live-deploy/

# Coverage-campaign run-local result artifacts + the systems descriptor
# (artifacts/coverage-campaign/systems.toml — real per-environment facts; embeds host
# FQDNs/IPs + secret refs. Scaffold from scripts/coverage_campaign/systems.toml.template.)
/artifacts/coverage-campaign/
