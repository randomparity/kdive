{
  "title": "kdive \u2014 Metrics Overview",
  "uid": "kdive-overview",
  "tags": [
    "kdive"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Data source",
        "hide": 0,
        "refresh": 1,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "MCP request plane",
      "collapsed": false,
      "id": 1,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Request rate by tool",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (tool) (rate(kdive_mcp_requests[$__rate_interval]))",
          "legendFormat": "{{tool}}",
          "refId": "A",
          "range": true
        }
      ],
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      }
    },
    {
      "type": "timeseries",
      "title": "Request errors by tool",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (tool) (rate(kdive_mcp_request_errors[$__rate_interval]))",
          "legendFormat": "{{tool}}",
          "refId": "A",
          "range": true
        }
      ],
      "id": 3,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      }
    },
    {
      "type": "timeseries",
      "title": "Request latency (p50/p95/p99)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.5, sum by (le) (rate(kdive_mcp_request_duration_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(kdive_mcp_request_duration_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(kdive_mcp_request_duration_bucket[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "C",
          "range": true
        }
      ],
      "id": 4,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      }
    },
    {
      "type": "timeseries",
      "title": "Debug-session duration (p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(kdive_debug_session_duration_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "A",
          "range": true
        }
      ],
      "id": 5,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      }
    },
    {
      "type": "row",
      "title": "Allocation / admission",
