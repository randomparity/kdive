          "refId": "A",
          "range": true
        }
      ],
      "id": 9,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 26
      }
    },
    {
      "type": "row",
      "title": "Lifecycle inventory",
      "collapsed": false,
      "id": 10,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "panels": []
    },
    {
