# KDIVE service environment (copy to /etc/kdive/kdive.env, chmod 0640, owner kdive).
# Backends are external and must be reachable; see docs/operating/systemd.md.
# Every name below is a registered setting; see docs/guide/reference/config.md.
# Fill in credentials from your secret store; never commit real secrets. The DSN below
# is intentionally credential-less — supply the user/password via your secret manager or
# a separate, non-committed env file.

# System-of-record Postgres DSN (required). Credential-less form; inject user/password
# from your secret store rather than committing them here.
KDIVE_DATABASE_URL=postgresql://db.internal:5432/kdive

# Object store (S3-compatible) for vmcores, transcripts, and uploads.
KDIVE_S3_ENDPOINT_URL=https://minio.internal:9000
KDIVE_S3_BUCKET=kdive
KDIVE_S3_REGION=us-east-1

# Object-store credentials come from boto3's default chain (the standard AWS_* vars).
# Supply real values from your secret store; do not commit them.
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me

# OIDC bearer-token verification (all three required by the server).
KDIVE_OIDC_ISSUER=https://oidc.internal/realms/kdive
KDIVE_OIDC_AUDIENCE=kdive
KDIVE_OIDC_JWKS_URI=https://oidc.internal/realms/kdive/protocol/openid-connect/certs
