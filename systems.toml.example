# kdive systems inventory descriptor (EXAMPLE) — schema v2 (ADR-0112).
#
# Copy to the inventory path and fill in your environment — the per-user XDG default
# `~/.config/kdive/systems.toml`, or wherever `KDIVE_SYSTEMS_TOML` points (a repo-root
# `systems.toml` is GITIGNORED but is only loaded when `KDIVE_SYSTEMS_TOML` names it; there is no
# working-directory fallback). This is the single declarative source of truth for the inventory
# the app loads into the database:
#
#   * `[[image]]`           -> reconciled into `image_catalog` (replaces the former in-code
#                             `images/seed_data/*.yaml` + `admin/default_fixtures.py` rootfs YAML
#                             and the `REMOTE_BASE_IMAGE_NAME` literal — all removed in Phase 1).
#   * `[[remote_libvirt]]` / `[[local_libvirt]]` / `[[fault_inject]]` / `[[build_host]]`
#                           -> reconciled into `resources` / `build_hosts` (Phases 2-3).
#                             Multiple `[[remote_libvirt]]` instances are now supported (ADR-0187,
#                             #395): per-op provider config selects the granted Resource's host by
#                             name, so you can pool several remote-libvirt hosts in one fleet.
#
# Load it with `kdive reconcile-systems` (or the deploy `migrate` step, or the reconciler loop).
# Path is `KDIVE_SYSTEMS_TOML` (default the XDG `~/.config/kdive/systems.toml`, ADR-0112; in k8s a
# mounted ConfigMap).
#
# WHOLE-FILE PARSE, ALL-OR-NOTHING: a present-but-malformed file fails the ENTIRE reconcile pass
# for that iteration — images, cost-class coefficients, resources, and build_hosts are all skipped
# until the file is corrected (the reconciler logs it and retries next pass). One bad block stalls
# every entity, not just its own. UPGRADE NOTE: `[[remote_libvirt]]` now REQUIRES `vcpus` and
# `memory_mb` (the billable size ceiling; admission denies any allocation on a host without it).
# A pre-existing file whose `[[remote_libvirt]]` block omits them parsed before but now fails to
# load — add both fields when upgrading.
# Operational/secret config stays in the `KDIVE_*` env registry (ADR-0087) — this file holds
# secret *refs* (filenames the SecretRegistry resolves), never secret material.
#
# NOTE: the coverage-campaign tooling (`scripts/coverage_campaign/systems.py`,
# `render-env`/`setup-commands`) reads THIS v2 file (#395): it parses the `[[remote_libvirt]]` /
# `[[image]]` connection via the shared inventory loader and reads campaign-only deployment knobs
# from the `[campaign]` table at the bottom (which the app's inventory loader ignores).

schema_version = 2

# ---------------------------------------------------------------------------------------------
# IMAGES — reconciled into image_catalog. `source` is exactly one of s3 | build | staged.
# ---------------------------------------------------------------------------------------------

# The kdump-capable local default rootfs (ADR-0251). Its makedumpfile (1.7.9) filters current
# from-source kernels, so the default `kdump` `vmcore.fetch` captures a complete core. Declared
# `s3`; it reaches `registered` once its object is published and a `digest` is supplied — until
# then it stays `defined`.
[[image]]
provider = "local-libvirt"
name = "fedora-kdive-ready-44"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = ["ssh", "selinux", "kdump", "drgn"]
[image.source]
kind = "s3"
object_key = "rootfs/local/fedora-kdive-ready-44.qcow2"
# digest = "sha256:…"   # uncomment once published to mark the row `registered`

# The kdive-ready local baseline rootfs (the former seed_data baseline), retained as the #817
# regression reference (ADR-0251): its makedumpfile (1.7.8) cannot filter the newest kernels, so
# the default `kdump` method leaves an incomplete core on a from-source kernel — use 44 for that.
# Declared `s3`; it reaches `registered` once its object is published and a `digest` is supplied —
# until then it stays `defined` (the same pre-build state the old YAML seed produced).
[[image]]
provider = "local-libvirt"
name = "fedora-kdive-ready-43"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = ["ssh", "selinux", "kdump", "drgn"]
[image.source]
kind = "s3"
object_key = "rootfs/local/fedora-kdive-ready-43.qcow2"
# digest = "sha256:…"   # uncomment once published to mark the row `registered`

# RHEL-family rootfs entries (Rocky 8/9/10 + CentOS Stream 9/10, ADR-0251 / #823), built via
# `build-fs --image <name>` from their sha256-pinned GenericCloud bases. NONE ship makedumpfile
# >= 1.7.9 yet, so the default `kdump` `vmcore.fetch` lands on the `kdump_core_incomplete`
# remediation for a v7.0-class kernel — use `method="host_dump"` (or fedora-kdive-ready-44) there.
# See docs/operating/runbooks/image-lifecycle.md for the per-release makedumpfile/kdump_capable
# table. Declared `s3`; each reaches `registered` once its object is published and a `digest` set.
[[image]]
provider = "local-libvirt"
name = "rocky-kdive-ready-8"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = ["ssh", "selinux", "kdump", "drgn"]
[image.source]
kind = "s3"
object_key = "rootfs/local/rocky-kdive-ready-8.qcow2"

[[image]]
provider = "local-libvirt"
name = "rocky-kdive-ready-9"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = ["ssh", "selinux", "kdump", "drgn"]
[image.source]
kind = "s3"
object_key = "rootfs/local/rocky-kdive-ready-9.qcow2"

[[image]]
provider = "local-libvirt"
name = "rocky-kdive-ready-10"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = ["ssh", "selinux", "kdump", "drgn"]
[image.source]
kind = "s3"
object_key = "rootfs/local/rocky-kdive-ready-10.qcow2"

[[image]]
provider = "local-libvirt"
name = "centos-stream-kdive-ready-9"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = ["ssh", "selinux", "kdump", "drgn"]
[image.source]
kind = "s3"
object_key = "rootfs/local/centos-stream-kdive-ready-9.qcow2"

[[image]]
provider = "local-libvirt"
name = "centos-stream-kdive-ready-10"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = ["ssh", "selinux", "kdump", "drgn"]
[image.source]
kind = "s3"
object_key = "rootfs/local/centos-stream-kdive-ready-10.qcow2"

# Debian-family rootfs entries (Debian 12 bookworm + 13 trixie, ADR-0251 / #824), built via
# `build-fs --image <name>` from their sha256-pinned genericcloud bases with the `debian` customizer.
# Both ship makedumpfile < 1.7.9, so the default `kdump` `vmcore.fetch` lands on the
# `kdump_core_incomplete` remediation for a v7.0-class kernel — use `method="host_dump"` (or
# fedora-kdive-ready-44) there.
[[image]]
provider = "local-libvirt"
name = "debian-kdive-ready-12"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = ["ssh", "apparmor", "kdump", "drgn"]
[image.source]
kind = "s3"
object_key = "rootfs/local/debian-kdive-ready-12.qcow2"

[[image]]
provider = "local-libvirt"
name = "debian-kdive-ready-13"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = ["ssh", "apparmor", "kdump", "drgn"]
[image.source]
kind = "s3"
object_key = "rootfs/local/debian-kdive-ready-13.qcow2"

# A `staged-path` source (local-libvirt only, ADR-0228) registers an operator-staged rootfs
# FILE — the qcow2 `build-fs` writes to local disk — without any object-store upload. It seeds
# `registered` (bootable) immediately and is discoverable from the MCP surface
# (`fixtures.list` / `systems.profile_examples`), so a host-shell-free agent can provision with
# `rootfs = {kind = "catalog", provider = "local-libvirt", name = "fedora-local"}`. The `path`
# must be absolute and under the provider `allowed_roots` (`/var/lib/kdive/rootfs`), and the
# image must be `public` (a private staged-path image is rejected at load).
[[image]]
provider = "local-libvirt"
name = "fedora-local"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = ["ssh", "selinux", "kdump", "drgn"]
[image.source]
kind = "staged-path"
path = "/var/lib/kdive/rootfs/local/fedora-kdive-ready-43.qcow2"

[[image]]
provider = "local-libvirt"
name = "fedora-cloud-43"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = []
[image.source]
kind = "s3"
object_key = "rootfs/local/fedora-cloud-43.qcow2"

[[image]]
provider = "local-libvirt"
name = "busybox-bare"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = []
[image.source]
kind = "s3"
object_key = "rootfs/local/busybox-bare.qcow2"

# The remote-libvirt provisioning base image (the former REMOTE_BASE_IMAGE_NAME literal). It is
# an operator-staged libvirt volume, so it is `staged` (no S3 object) and registers immediately.
[[image]]
provider = "remote-libvirt"
name = "fedora-kdive-remote-base-43"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
[image.source]
kind = "staged"
volume = "fedora-kdive-remote-base-43.qcow2"

# ---------------------------------------------------------------------------------------------
# PROVIDER INSTANCES — reconciled into resources (Phase 2-3; shown here for reference).
# ---------------------------------------------------------------------------------------------

# Remote-libvirt supports multiple instances (ADR-0187, #395): declare as many [[remote_libvirt]]
# blocks as you have hosts to pool. Per-op provider config selects the granted Resource's host by
# its instance `name`, so allocations, builds, console hosting, reapers, and diagnostics each reach
# the right host in a multi-host fleet.
# [[remote_libvirt]]
# name = "ub24-big"
# uri = "qemu+tls://ub24-big.example/system"
# gdb_addr = "192.168.10.20"
# gdbstub_range = "47000:47099"
# client_cert_ref = "remote-clientcert.pem"
# client_key_ref = "remote-clientkey.pem"   # pragma: allowlist secret - filename ref
# ca_cert_ref = "remote-ca.pem"
# base_image = "fedora-kdive-remote-base-43"   # -> an [[image]] name
# cost_class = "remote"
# concurrent_allocation_cap = 1
# pool groups interchangeable hosts for first-available `allocations.request(pool=...)`
# selection (ADR-0186). Absent -> "default". Put identically-configured hosts in one pool so
# an agent can request the pool instead of naming a specific host.
# pool = "big-remote"
# vcpus and memory_mb are the host's billable size ceiling. Admission's <=-resource-caps
# check reads them off the Resource, so a remote host without them is un-grantable
# (allocations.request -> configuration_error). Remote-libvirt is config-owned, so the file
# is the only place this ceiling comes from; both are required.
# vcpus = 16
# memory_mb = 65536
# shapes = ["small", "medium", "large", "max"]

# Local-libvirt does NOT declare vcpus/memory_mb here: its size ceiling is probed by discovery
# and merged onto the row, so this overlay only sets name/cost_class/concurrent_allocation_cap.
# [[local_libvirt]]
# name = "workstation"
# host_uri = "qemu:///system"
# cost_class = "local"
# concurrent_allocation_cap = 1

# Fault-inject (the synthetic, hardware-free provider) is now created ONLY from this file
# (Phase 2, #393): reconcile_resources is its sole creator and the vcpus/memory_mb below are
# the billable sizing the row advertises to admission — without them allocations.request(
# kind=fault-inject) is denied configuration_error (#385). Uncomment to make it allocatable.
# Array-of-tables = multiple instances (Phase 3, #394): declare as many [[fault_inject]] blocks
# as you need; they share the synthetic host_uri (fault-inject://local) and coexist via the
# (kind, name) identity, each an independently allocatable resource.
# [[fault_inject]]
# name = "synthetic-1"
# cost_class = "local"
# concurrent_allocation_cap = 1
# vcpus = 8
# memory_mb = 8192
# pool = "default"   # optional; group interchangeable hosts for by-pool allocation (ADR-0186)
# seed = 1337
# [[fault_inject]]
# name = "synthetic-2"
# cost_class = "local"
# concurrent_allocation_cap = 1
# vcpus = 16
# memory_mb = 16384
# seed = 7331

# ---------------------------------------------------------------------------------------------
# BUILD HOSTS — reconciled into build_hosts (Phase 3, #394).
# ---------------------------------------------------------------------------------------------
#
# Only `local` and `ephemeral_libvirt` hosts are config-expressible: the v2 [[build_host]] model
# carries no address/ssh_credential_ref, so an `ssh` host is registered imperatively via
# `build_hosts.register` (which carries those fields) and is warned-and-skipped if declared here.
# An `ephemeral_libvirt` host requires `base_image_volume`; a `local` host must omit it.
# Declaring the seeded `worker-local` row here ADOPTS it (flips managed_by runtime -> config).

# [[build_host]]
# name = "ub24-big-ephemeral"
# kind = "ephemeral_libvirt"
# base_image_volume = "fedora-kdive-remote-base-43.qcow2"
# workspace_root = "/var/lib/kdive/build"
# max_concurrent = 2

# ---------------------------------------------------------------------------------------------
# COST CLASSES — reconciled into cost_class_coefficients (ADR-0115).
#
# Each [[cost_class]] declares the pricing coefficient for a cost_class label a host carries
# (the [[remote_libvirt]]/[[fault_inject]] `cost_class` field). The file is authoritative:
# a declared coefficient is re-asserted on every reconcile, so an `ops.set_cost_class_coeff`
# override on a declared class is transient — edit this file to change a declared price.
#
# A host whose cost_class has no matching block here (and is not a seeded `local`/`remote`)
# is admitted into the catalog but DENIED every allocation (configuration_error). Declare the
# block to price it. `coeff` may be a number (2.5) or a quoted decimal string ("2.5"); the
# latter is what `ops.export_cost_classes` emits for an exact round-trip.
# ---------------------------------------------------------------------------------------------

[[cost_class]]
name = "remote"
coeff = "1.0"

# ---------------------------------------------------------------------------------------------
# BUILD-CONFIG FRAGMENTS — reconciled into build_config_catalog (ADR-0122).
#
# Each [[build_config]] declares a named kernel-config fragment inline. reconcile-systems
# publishes the `content` bytes to the reserved object key and upserts the catalog row with
# source='config'. The file is AUTHORITATIVE: a declared fragment overrides a live
# `buildconfig.set` (which writes source='operator') and is re-asserted on every reconcile, so
# edit this file to change a declared fragment — a buildconfig.set on a declared name is
# transient (break-glass only). A name NOT declared here keeps buildconfig.set's durability.
#
# Removing a [[build_config]] block is a no-op: the catalog row persists at its last bytes
# (upsert-only, never pruned). `content` is capped at KDIVE_MAX_BUILD_CONFIG_BYTES (256 KiB);
# an over-cap fragment fails `reconcile-systems --check` at deploy.
# ---------------------------------------------------------------------------------------------

# [[build_config]]
# name = "kdump"
# description = "kdump/debuginfo kernel-config fragment"
# content = """
# CONFIG_KEXEC=y
# CONFIG_CRASH_DUMP=y
# CONFIG_DEBUG_INFO=y
# # remote-libvirt's base image root is XFS; keep these or the built kernel cannot mount it
# # and boots to emergency mode (ADR-0183). Declaring this fragment overrides the packaged
# # seed, so a remote deployment must carry them here too.
# CONFIG_XFS_FS=y
# CONFIG_XFS_POSIX_ACL=y
# """

# ---------------------------------------------------------------------------------------------
# COVERAGE-CAMPAIGN KNOBS — read ONLY by scripts/coverage_campaign/systems.py, ignored by the
# app's inventory loader. These are the per-deployment facts the campaign needs that are not part
# of the declarative inventory: workstation paths, the remote host's network/SSH/ACL facts, and
# the k8s port-forward topology. The campaign's render-env points the app at this file via
# KDIVE_SYSTEMS_TOML and reads the remote *connection* (uri/cert refs/gdb addr/gdbstub range) from
# the [[remote_libvirt]] block above — these tables carry only what the inventory model lacks.
# ---------------------------------------------------------------------------------------------

# [campaign.workstation]
# fault_inject = true
# secrets_root = "/home/you/.kdive-secrets"
# build_workspace = "/work/.live-build"
# build_component_roots = "/work/fixtures/local-libvirt:/work/.live-components"
# s3_endpoint_url = "http://<workstation-lan-ip>:9000"   # reachable FROM the remote guest
# lan_ip = "<workstation-lan-ip>"

# [campaign.remote_libvirt]
# host_fqdn = "ub24-big.example"
# host_ip = "192.168.10.20"
# ssh_target = "you@ub24-big.example"
# tls_port = 16514
# acl_source_ip = "<workstation-lan-ip>"   # defaults to campaign.workstation.lan_ip

# [campaign.k8s]
# context = "kdive-d2"
# namespace = "kdive"
# oidc_forward = "svc/oidc"
# oidc_local_port = 8080
# oidc_service_port = 80
# server_forward = "svc/server"
# server_local_port = 8081
# server_service_port = 80
# in_cluster_issuer = "http://oidc.kdive.svc/realms/kdive"
